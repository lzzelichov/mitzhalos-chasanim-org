# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env.local` and fill in your own values.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# Stripe (Developers → API keys)
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx                   # from `stripe listen` or the dashboard

# Admin upload page password (choose anything)
ADMIN_PASSWORD=change-me

# Public base URL (no trailing slash). Used for Stripe redirect URLs.
# On Vercel you can leave this unset — the app falls back to VERCEL_URL automatically.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Email confirmations (optional). Get a free key at resend.com — emails are
# skipped (logged) if not set; the webhook never fails because of email.
# RESEND_API_KEY=re_xxx
# EMAIL_FROM=Our Wedding Fund <onboarding@resend.dev>
# ADMIN_EMAIL=you@example.com   # receives a "new donation" alert

# Date range shown on the home grid (inclusive)
START_DATE=2025-06-01
END_DATE=2025-06-30

# OPTIONAL fallbacks used only when the `site_config` table has no row.
# Once you add a site_config row in Supabase, those values take precedence.
GOAL_AMOUNT=10000
COUPLE_NAME=מצהלות חתנים / Mitzhalos Chasanim

# Donation currency — USD only.
NEXT_PUBLIC_DEFAULT_CURRENCY=USD

# WhatsApp blessing share button (set "false" to disable)
NEXT_PUBLIC_WHATSAPP_ENABLED=true
