# ─────────────────────────────────────────────────────────────
#  Copy this file to `.env.local` and fill in your own values.
#  Mitzhalos Chasanim — USD only.
# ─────────────────────────────────────────────────────────────

# Supabase (Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# Stripe (Developers → API keys). USD only.
STRIPE_SECRET_KEY=sk_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx                   # from `stripe listen` or the dashboard

# Admin dashboard password (/admin)
ADMIN_PASSWORD=change-me

# Public base URL (no trailing slash). On Vercel you can leave this unset —
# it falls back to VERCEL_URL automatically.
NEXT_PUBLIC_SITE_URL=http://localhost:3001

# Contact-form emails (optional). Without it, messages are still saved to the
# `contacts` table; the form never fails because email isn't configured.
RESEND_API_KEY=
EMAIL_FROM=Mitzhalos Chasanim <onboarding@resend.dev>
